# Environment Variables

# AI Provider Priority (comma-separated, default: yescale,deepseek,gemini,openai,anthropic)
AI_PROVIDER_PRIORITY=yescale,deepseek,gemini,openai,anthropic

# AI API Keys (at least one required for chat functionality)
YESCALE_API_KEY=your-yescale-key
DEEPSEEK_API_KEY=your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key

# Optional: Model overrides
# YESCALE_MODEL=gemini-2.5-flash-lite
# DEEPSEEK_MODEL=deepseek-v4-flash
# GEMINI_MODEL=gemini-2.0-flash-lite

# Cloudflare (optional, for deploy via wrangler)
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Optional: Analytics
# ANALYTICS_ID=your-analytics-id
