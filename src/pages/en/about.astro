---
import Layout from '@layouts/BaseLayout.astro';
import { getTranslations, t } from '@/i18n/utils';
import aboutData from '@/data/jeremy.json';
import careerData from '@/data/jeremy.json';
import AboutBio from '@components/sections/AboutBio.astro';
import AboutPhilosophy from '@components/sections/AboutPhilosophy.astro';
import AboutDomains from '@components/sections/AboutDomains.astro';
import AboutTimeline from '@components/sections/AboutTimeline.astro';
import { SITE_URL, SAME_AS } from '@/config/social-links';

const locale: 'en' | 'vi' = Astro.currentLocale === 'vi' ? 'vi' : 'en';
const translations = getTranslations(locale);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nguyen Tung Anh (Jeremy Nguyen)',
  jobTitle: 'Software Engineer | Technical Leader',
  url: SITE_URL,
  sameAs: SAME_AS,
};
---

<Layout title={t(translations, 'meta.aboutTitle')} description={t(translations, 'meta.aboutDescription')} ogTitle={t(translations, 'meta.ogAboutTitle')} image="/og-default.png">
  <div class="about-page">
    <svg style="position: absolute; width: 1px; height: 1px; overflow: hidden;" aria-hidden="true">
      <filter id="grainFilter" x="0" y="0" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch">
          <animate attributeName="baseFrequency" values="0.65;0.75;0.65" dur="0.4s" repeatCount="indefinite" />
        </feTurbulence>
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>

    <div class="ambient-orb orb-1"></div>
    <div class="ambient-orb orb-2"></div>
    <div class="ambient-orb orb-3"></div>

    <div class="about-wrapper">
      <div class="about-band about-band-hero">
        <AboutBio translations={translations} locale={locale} />
      </div>
      <div class="about-band">
        <AboutPhilosophy translations={translations} />
      </div>
      <div class="about-band">
        <AboutDomains translations={translations} domains={aboutData.domains} />
      </div>
      <div class="about-band">
        <AboutTimeline translations={translations} timeline={careerData.career.timeline} />
      </div>
    </div>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</Layout>

<script is:inline>
(function() {
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '-32px' });
  document.querySelectorAll('.reveal-section, .reveal-item, .reveal-tag').forEach(function(el) {
    observer.observe(el);
  });
})();
</script>

<style>
  .about-page {
    padding-top: 8px;
    position: relative;
    max-width: none;
    margin: 0 -18px;
  }
  @media (min-width: 768px) {
    .about-page {
      margin: 0 -40px;
    }
  }
  .about-page::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 60;
    opacity: 0.035;
    mix-blend-mode: overlay;
    filter: url(#grainFilter);
  }
  @media (prefers-reduced-motion: reduce) {
    .about-page::before {
      display: none;
    }
  }

  .about-wrapper {
    display: flex;
    flex-direction: column;
  }
  .about-band {
    position: relative;
  }
  .about-band:nth-child(even) {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .about-band :global(.about-section) {
    padding: 32px 0;
  }
  @media (min-width: 768px) {
    .about-band :global(.about-section) {
      padding: 48px 0;
    }
  }
  @media (min-width: 1024px) {
    .about-band :global(.about-section-inner) {
      max-width: min(780px, calc(100% - 120px));
      margin-left: clamp(48px, 7vw, 96px);
      margin-right: auto;
    }
  }

  .reveal-section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--index) * 80ms);
  }
  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-tag {
    opacity: 0;
    transform: scale(0.92);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--index) * 60ms);
  }
  .reveal-tag.is-visible {
    opacity: 1;
    transform: scale(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-section,
    .reveal-item,
    .reveal-tag {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .ambient-orb {
    display: none;
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }
  .orb-1 {
    width: 320px; height: 320px;
    background: rgba(209,122,88,0.18);
    top: 10%; left: -5%;
    animation: floatA 18s ease-in-out infinite alternate;
  }
  .orb-2 {
    width: 240px; height: 240px;
    background: rgba(234,230,216,0.35);
    top: 40%; right: -8%;
    animation: floatB 22s ease-in-out infinite alternate;
  }
  .orb-3 {
    width: 180px; height: 180px;
    background: rgba(184,92,60,0.12);
    bottom: 15%; left: 30%;
    animation: floatC 26s ease-in-out infinite alternate;
  }
  @keyframes floatA {
    from { transform: translate3d(0,0,0); }
    to { transform: translate3d(60px,-40px,0); }
  }
  @keyframes floatB {
    from { transform: translate3d(0,0,0); }
    to { transform: translate3d(-50px,30px,0); }
  }
  @keyframes floatC {
    from { transform: translate3d(0,0,0); }
    to { transform: translate3d(30px,50px,0); }
  }

  [data-theme="dark"] .orb-1 { background: rgba(209,122,88,0.10); }
  [data-theme="dark"] .orb-2 { background: rgba(46,43,39,0.25); }
  [data-theme="dark"] .orb-3 { background: rgba(184,92,60,0.08); }

  @media (min-width: 768px) {
    .ambient-orb {
      display: block;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ambient-orb {
      display: none;
    }
  }
</style>
