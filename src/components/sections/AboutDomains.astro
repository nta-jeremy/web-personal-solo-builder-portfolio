---
import { t } from '@/i18n/utils';

export interface Props {
  translations: Record<string, unknown>;
  domains: string[];
}

const { translations, domains } = Astro.props;
---

<section class="about-domains about-section reveal-section">
  <div class="about-section-inner">
    <span class="about-section-label">{t(translations, 'about.domainsLabel')}</span>
    <span class="about-section-label-vertical">{t(translations, 'about.domainsLabel')}</span>
    <div class="about-domains-grid">
      {domains.map((domain, i) => (
        <div class="about-domain-item reveal-tag" style={`--index: ${i}`}>
          <span class="about-domain-dot" aria-hidden="true"></span>
          <span class="about-domain-name">{domain}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-domains {
    margin-bottom: 0;
    position: relative;
  }
  .about-section-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 18px;
  }
  .about-section-label {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 14px;
  }
  .about-domains-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px 20px;
  }
  .about-domain-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--ink-2);
  }
  .about-domain-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
  .about-domain-name {
    letter-spacing: 0.01em;
  }
  @media (min-width: 640px) {
    .about-domains-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 768px) {
    .about-section-inner {
      padding-left: 56px;
    }
    .about-section-label {
      display: none;
    }
    .about-section-label-vertical {
      display: block;
      position: absolute;
      left: 18px;
      top: 32px;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 10.5px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
    }
  }
  .about-section-label-vertical {
    display: none;
  }

</style>
