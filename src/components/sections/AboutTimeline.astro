---
import { t } from '@/i18n/utils';

export interface Props {
  translations: Record<string, unknown>;
  timeline: Array<{ year: string; title: string; desc: string }>;
}

const { translations, timeline } = Astro.props;
---

<section class="about-timeline about-section reveal-section">
  <div class="about-section-inner">
    <span class="about-section-label">{t(translations, 'about.timelineLabel')}</span>
    <span class="about-section-label-vertical">{t(translations, 'about.timelineLabel')}</span>
    <div class="about-timeline-list">
      {timeline.map((item, index) => (
        <div class="about-timeline-item reveal-item" style={`--index: ${index}`}>
          <div class="about-timeline-node" aria-hidden="true"></div>
          <div class="about-timeline-content">
            <div class="about-timeline-meta">
              <span class="about-timeline-year mono">{item.year}</span>
              <span class="about-timeline-title serif">{item.title}</span>
            </div>
            <p class="about-timeline-desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-timeline {
    margin-bottom: 0;
    position: relative;
  }
  .about-section-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 18px;
  }
  .about-section-label {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 16px;
  }
  .about-timeline-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 24px;
  }
  .about-timeline-list::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border-2);
  }
  .about-timeline-item {
    position: relative;
    padding: 0 0 24px 16px;
  }
  .about-timeline-item:last-child {
    padding-bottom: 0;
  }
  .about-timeline-node {
    position: absolute;
    left: -20px;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg);
    z-index: 1;
  }
  .about-timeline-item::before {
    content: '';
    position: absolute;
    left: -20px;
    top: 6px;
    width: 2px;
    height: calc(100% + 24px);
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--index) * 80ms);
    z-index: 0;
  }
  .about-timeline-item:last-child::before {
    height: 100%;
  }
  .about-timeline-item.is-visible::before {
    transform: scaleY(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .about-timeline-item::before {
      transition: none;
      transform: scaleY(1);
    }
  }
  .about-timeline-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .about-timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .about-timeline-year {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
    padding-top: 2px;
    font-family: var(--font-mono);
  }
  .about-timeline-title {
    font-style: italic;
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .about-timeline-desc {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  @media (min-width: 768px) {
    .about-timeline-list {
      padding-left: 28px;
    }
    .about-timeline-list::before {
      left: 8px;
    }
    .about-timeline-node {
      left: -20px;
      top: 8px;
      width: 12px;
      height: 12px;
    }
    .about-timeline-item::before {
      left: -20px;
      top: 8px;
      width: 2px;
      height: calc(100% + 28px);
    }
    .about-timeline-item {
      padding: 0 0 28px 20px;
    }
    .about-timeline-title {
      font-size: 19px;
    }
    .about-section-inner {
      padding-left: 56px;
    }
    .about-section-label {
      display: none;
    }
    .about-section-label-vertical {
      display: block;
      position: absolute;
      left: 18px;
      top: 32px;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 10.5px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
    }
  }
  .about-section-label-vertical {
    display: none;
  }
</style>
