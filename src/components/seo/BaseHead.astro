---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  canonicalUrl?: string;
  hreflang?: Array<{ lang: string; url: string }>;
  ogTitle?: string;
  ogDescription?: string;
  ogImageAlt?: string;
  locale?: string;
  publishedDate?: string;
  modifiedDate?: string;
  tags?: string[];
}

const {
  title,
  description = 'Personal portfolio of Jeremy Nguyen',
  image = '/og-default.png',
  type = 'website',
  noindex = false,
  canonicalUrl,
  hreflang = [],
  ogTitle,
  ogDescription,
  ogImageAlt,
  locale = 'vi_VN',
  publishedDate,
  modifiedDate,
  tags = [],
} = Astro.props;

const { pathname } = Astro.url;
const site = 'https://jeremytech.io.vn';
const canonical = canonicalUrl || `${site}${pathname}`;
const ogImage = image.startsWith('http') ? image : `${site}${image}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="theme-color" content="#0a0a0a" />
<meta name="author" content="Jeremy Nguyen" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonical} />

{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={ogTitle || title} />
<meta property="og:description" content={ogDescription || description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt || title} />
<meta property="og:site_name" content="Jeremy Nguyen" />
<meta property="og:locale" content={locale} />

<!-- Article-specific OG -->
{
  type === 'article' && (
    <>
      <meta property="article:author" content="Jeremy Nguyen" />
      {publishedDate && <meta property="article:published_time" content={publishedDate} />}
      {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
      {tags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@Ichimoku2502" />
<meta name="twitter:creator" content="@Ichimoku2502" />
<meta name="twitter:title" content={ogTitle || title} />
<meta name="twitter:description" content={ogDescription || description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt || title} />

<!-- Hreflang alternates -->
{
  hreflang.map(({ lang, url }) => (
    <link rel="alternate" hreflang={lang} href={url} />
  ))
}
