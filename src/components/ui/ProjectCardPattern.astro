---
export interface Props {
  pattern: number;
}

const { pattern } = Astro.props;
---

<svg width="100%" height="100%" style="position: absolute; inset: 0; opacity: 0.5;">
  {pattern === 0 && (
    <g stroke="#f4d4b5" stroke-width="0.4" fill="none">
      {Array.from({ length: 24 }).map((_, j) => (
        <line
          x1="50%"
          y1="50%"
          x2={`${50 + 45 * Math.cos(j * 0.26)}%`}
          y2={`${50 + 40 * Math.sin(j * 0.26)}%`}
        />
      ))}
      <circle cx="50%" cy="50%" r="3" fill="#f4d4b5" stroke="none" />
    </g>
  )}
  {pattern === 1 && (
    <g fill="#d4a876">
      {Array.from({ length: 6 }).map((_, j) => (
        <rect
          x={16 + j * 28}
          y={20 + j * 6}
          width="20"
          height="60"
          opacity={0.25 + j * 0.1}
        />
      ))}
    </g>
  )}
  {pattern === 2 && (
    <g fill="none" stroke="#f4d4b5" stroke-width="0.6">
      <path d="M10 90 L50 30 L90 70 L130 20 L170 80 L210 40" />
      <path d="M10 70 L50 20 L90 50 L130 15 L170 60" />
    </g>
  )}
</svg>
