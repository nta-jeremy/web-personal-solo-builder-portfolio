---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { data } = post;

const slug = post.id.replace(/^(en|vi)\//, '');
const href = data.locale === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;

const dateFmt = new Date(data.pubDate).toLocaleDateString(
  data.locale === 'vi' ? 'vi-VN' : 'en-US',
  { year: 'numeric', month: 'short', day: 'numeric' }
);

// Deterministic pattern based on slug length
const patternIndex = slug.length % 3;
---

<article class="blog-card">
  <a href={href} class="card-link" aria-label={data.title}>
    <div class="card-image">
      <div class={`image-gradient pattern-${patternIndex}`}>
        <svg width="100%" height="100%" class="image-svg" preserveAspectRatio="none">
          {patternIndex === 0 && (
            <g stroke="#f4d4b5" stroke-width="0.4" fill="none">
              {Array.from({ length: 20 }).map((_, j) => (
                <line
                  x1="50%"
                  y1="50%"
                  x2={`${50 + 40 * Math.cos(j * 0.32)}%`}
                  y2={`${50 + 35 * Math.sin(j * 0.32)}%`}
                />
              ))}
              <circle cx="50%" cy="50%" r="3" fill="#f4d4b5" stroke="none" />
            </g>
          )}
          {patternIndex === 1 && (
            <g fill="#d4a876">
              {Array.from({ length: 6 }).map((_, j) => (
                <rect
                  x={`${15 + j * 14}%`}
                  y={`${30 + j * 3}%`}
                  width="10%"
                  height="50%"
                  opacity={0.25 + j * 0.1}
                />
              ))}
            </g>
          )}
          {patternIndex === 2 && (
            <g fill="none" stroke="#f4d4b5" stroke-width="0.6">
              <path d="M0 80 L40 30 L80 60 L120 20 L160 70 L200 40 L240 65" />
              <path d="M0 60 L40 20 L80 40 L120 15 L160 50 L200 30 L240 45" />
            </g>
          )}
        </svg>
      </div>
    </div>

    <div class="card-meta">
      <span class="meta-date mono">{dateFmt.toUpperCase()}</span>
      <span class="meta-dot" />
      <span class="tag accent">{data.category}</span>
    </div>

    <h2 class="card-title serif">{data.title}</h2>
    <p class="card-excerpt">{data.description}</p>
  </a>
</article>

<style>
  .blog-card {
    border-bottom: 1px solid var(--border);
    padding: 24px 0;
  }

  .blog-card:first-child {
    border-top: 1px solid var(--border);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-image {
    width: 100%;
    height: 150px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 14px;
  }

  @media (min-width: 768px) {
    .card-image {
      width: 180px;
      height: 120px;
      float: right;
      margin-left: 28px;
      margin-bottom: 0;
    }

    .card-link::after {
      content: '';
      display: block;
      clear: both;
    }
  }

  .image-gradient {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .pattern-0 {
    background: radial-gradient(circle at 40% 50%, #8a6a54 0%, #2c211d 70%);
  }

  .pattern-1 {
    background: linear-gradient(160deg, #4a3d33, #1c1612);
  }

  .pattern-2 {
    background: linear-gradient(135deg, #6b4a38, #2c1e17);
  }

  .image-svg {
    position: absolute;
    inset: 0;
    opacity: 0.5;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .meta-date {
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.1em;
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    background: var(--subtle);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .card-title {
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }

  @media (min-width: 768px) {
    .card-title {
      font-size: 30px;
      line-height: 1.15;
    }
  }

  .card-excerpt {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
    max-width: 460px;
  }
</style>
